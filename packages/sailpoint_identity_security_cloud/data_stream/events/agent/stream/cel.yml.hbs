config_version: 2
interval: {{interval}}
{{#if enable_request_tracer}}
resource.tracer.filename: "../../logs/cel/http-request-trace-*.ndjson"
request.tracer.maxbackups: 5
{{/if}}
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
max_executions: {{max_executions}}
resource.url: {{api_host}}
auth:
  oauth2:
    client:
      id: {{client_id}}
      secret: {{client_secret}}
    token_url: "{{api_host}}/oauth/token"
    endpoint_params:
      grant_type: "client_credentials"
state:
  want_more: false
  limit: {{limit}}
  initial_interval: {{initial_interval}}
program: |-
  state.with(
  	request(
  		"POST",
  		state.url.trim_right("/") + "/v2024/search/events?" + state.limit
  	).with(
  		{
  			"Header": {
  				"Content-Type": ["application/json"],
  			},
  			"Body": {
  				"searchAfter": [],
  				"queryType": "SAILPOINT",
  				"sort": ["created"],
  				"query": string((now - duration(state.initial_interval)).format(time_layout.RFC3339)).split("-").join("\\\\-").split(":").join("\\:"),
  				"queryResultFilter": {},
  			}.encode_json(),
  		}
  	).do_request().as(resp,
  		bytes(resp.Body).decode_json().as(body,
  			{
  				"events": body.map(e,
  					{
  						"message": e.encode_json(),
  					}
  				),
  				"want_more": false,
  			}
  		)
  	)
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}